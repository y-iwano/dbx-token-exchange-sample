# Entra ID
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Databricks
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net

# Server
BASE_URL=https://your-domain.com
PORT=3000

# Entra ID access token version to accept: "1" or "2" (default: "2").
# "2" = v2 endpoint (iss: login.microsoftonline.com/.../v2.0) — set requestedAccessTokenVersion=2 in App manifest.
# "1" = v1 endpoint (iss: sts.windows.net)                    — set requestedAccessTokenVersion=null or 1 in App manifest.
# ENTRA_VERSION=2

# Application ID URI of the Entra App Registration.
# Used to validate the aud claim and to prefix scopes in OAuth metadata.
# Defaults to api://<AZURE_CLIENT_ID> if not set.
# Set to BASE_URL/mcp to align with the resource parameter sent by MCP Inspector.
IDENTIFIER_URI=https://your-domain.com/mcp

# OAuth scopes advertised to MCP clients (JSON array).
# Defaults to ["openid", "api://<AZURE_CLIENT_ID>/access"] if not set.
# Must match the App ID URI and scope defined in Azure Portal "Expose an API".
OAUTH_SCOPES='["openid", "https://your-domain.com/mcp/access"]'

# Short-form scope names required in incoming token scp claims (JSON array).
# Must match scope names defined in Azure Portal "Expose an API".
REQUIRED_SCOPES='["access"]'

# Managed MCP servers to proxy (JSON array).
# Available path patterns:
#   Genie Space:          /api/2.0/mcp/genie/{genie_space_id}
#   Databricks SQL:       /api/2.0/mcp/sql
#   Vector Search:        /api/2.0/mcp/vector-search/{catalog}/{schema}/{index_name}
#   Unity Catalog Funcs:  /api/2.0/mcp/functions/{catalog}/{schema}
#
# "name" is used as the tool namespace prefix (e.g. "genie" → tools named "genie_*")
# "name" must be lowercase alphanumeric with hyphens/underscores only
MCP_SERVERS='[{"name": "genie", "path": "/api/2.0/mcp/genie/<genie_space_id>"}, {"name": "sql", "path": "/api/2.0/mcp/sql"}]'
